# Application
PORT=3000
ADMIN_KEY=replace-with-a-long-random-secret

# Database
# Leave DATABASE_URL empty to use data/exam-system.sqlite locally.
DATABASE_URL=
# Set to false only when connecting to a local PostgreSQL server without TLS.
DATABASE_SSL=true
DATABASE_READINESS_TIMEOUT_MS=3000

# Encrypted automatic backup (BACKUP_ENCRYPTION_KEY must be at least 32 characters)
BACKUP_ENABLED=false
BACKUP_DIR=./data/backups
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_KEY=

# External JSON webhook monitoring (generic webhook or automation relay)
ALERT_WEBHOOK_URL=
MONITOR_INTERVAL_SECONDS=60
ALERT_COOLDOWN_MINUTES=15
ALERT_ERROR_RATE_PERCENT=5
ALERT_QUEUE_PERCENT=80

# Background jobs
JOB_CONCURRENCY=2
JOB_MAX_PENDING=100
JOB_RETRY_BASE_MS=1000

# Supabase Storage (optional)
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=exam-assets

# Google Forms OAuth (optional)
GOOGLE_FORMS_CLIENT_ID=
GOOGLE_FORMS_CLIENT_SECRET=
GOOGLE_FORMS_REDIRECT_URI=
