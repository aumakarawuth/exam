# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าให้เรียบร้อยก่อนใช้งานจริง

# รหัสผ่านสำหรับเข้าโหมดผู้ดูแลระบบ (แก้เป็นรหัสของจริง อย่าใช้ค่าเริ่มต้นตอน deploy จริง)
ADMIN_KEY=changeme123

# PostgreSQL connection string (for example, from Neon). When omitted, local SQLite is used.
DATABASE_URL=
# Set to false only when connecting to a local PostgreSQL server without TLS.
DATABASE_SSL=true

# พอร์ตที่ต้องการรันเซิร์ฟเวอร์
PORT=3000
